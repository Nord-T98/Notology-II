#include <iostream>
#include <fstream>
#include <Windows.h>

int main() {

    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);

    int size;
    std::cout << "Введите размер массива: ";
    std::cin >> size;

    if (size <= 0) {
        std::cerr << "Ошибка: размер массива должен быть положительным!" << std::endl;
        return 1;
    }

    int* arr = new int[size];

    for (int i = 0; i < size; i++) {
        std::cout << "arr[" << i << "] = ";
        std::cin >> arr[i];
    }

    std::ofstream file("out.txt");
    if (!file) {
        std::cerr << "Ошибка: не удалось открыть файл out.txt для записи!" << std::endl;
        delete[] arr;
        return 1;
    }

    file << size << std::endl;

    for (int i = size - 1; i >= 0; i--) {
        file << arr[i] << " ";
    }
    file << std::endl;

    file.close();  
    delete[] arr;    
    std::cout << "Массив успешно записан в out.txt!" << std::endl;

    return 0;
}
