#include <iostream>
#include <string>
#include <Windows.h>

int main() {

    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);

    std::string secret = "малина";
    std::string guess;

    do {
        std::cout << "Угадайте слово: ";
        std::cin >> guess;

        if (guess != secret) {
            std::cout << "Неправильно" << std::endl;
        }

    } while (guess != secret);

    std::cout << "Правильно! Вы победили! Загаданное слово — "
        << secret << std::endl;

    return 0;
}
